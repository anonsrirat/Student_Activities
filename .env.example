# Google OAuth 2.0
# สร้างได้ที่ https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# Secret keys (เปลี่ยนเป็นสตริงสุ่มอย่างน้อย 32 ตัวอักษร)
SESSION_SECRET=change_this_to_random_secret_min_32_chars
JWT_SECRET=change_this_to_random_jwt_secret_min_32_chars

# Domain restriction (เฉพาะ email TSU)
TSU_DOMAIN=tsu.ac.th

# Server
PORT=3000
